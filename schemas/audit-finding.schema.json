{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybercube.example/schemas/audit-finding.v1.json",
  "title": "CYBERCUBE Audit Finding — schema (STD-GOV-004)",
  "description": "Machine-readable contract for internal-audit findings referenced by STD-GOV-004. The finding-tracker lint enforces this schema and cross-references UCM control IDs (STD-GOV-006).",
  "type": "array",
  "items": { "$ref": "#/$defs/finding" },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["id", "audit_id", "title", "severity", "status", "owner", "opened", "control_ids"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^AF-[0-9]{6}$",
          "description": "Zero-padded 6-digit finding ID prefixed 'AF-' (audit finding)."
        },
        "audit_id": {
          "type": "string",
          "description": "Identifier of the audit engagement that raised this finding."
        },
        "title": { "type": "string", "minLength": 3, "maxLength": 200 },
        "description": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "informational"]
        },
        "status": {
          "type": "string",
          "enum": ["open", "in-remediation", "remediated", "accepted", "closed", "rejected"]
        },
        "owner": {
          "type": "string",
          "description": "Named role accountable for remediation."
        },
        "opened": { "type": "string", "format": "date" },
        "target_close_date": { "type": "string", "format": "date" },
        "closed_date": { "type": "string", "format": "date" },
        "control_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Unified Control Matrix (STD-GOV-006) control IDs impacted."
          },
          "minItems": 1
        },
        "linked_risks": {
          "type": "array",
          "items": { "type": "string", "pattern": "^RISK-[0-9]{4}$" }
        },
        "linked_exceptions": {
          "type": "array",
          "items": { "type": "string", "description": "Waiver IDs from STD-GOV-003." }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "description": "URI or path to evidence artifact." }
        },
        "recommendations": { "type": "string" },
        "management_response": { "type": "string" }
      }
    }
  }
}
